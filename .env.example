# kby-ai IDCardRecognition license key
# Get one at https://github.com/kby-ai/IDCardRecognition-Docker
# Leave blank and set OCR_MOCK_MODE=true to test without a key
KBY_LICENSE_KEY=

# Set to true to use mock scan data (no API key needed, for development)
OCR_MOCK_MODE=false

# URL of the OCR sidecar (set automatically in Docker Compose)
OCR_SERVICE_URL=http://ocr-service:8080

# Brother QL printer model (QL-810W, QL-820NWB, QL-1110NWB, etc.)
# Use "generic" for non-Brother printers that accept raw data on port 9100
PRINTER_MODEL=QL-810W

# Optional: force the /24 subnet to scan for the printer
# Auto-detected from the server's own IP if left blank
# PRINTER_SUBNET=192.168.1

# Google Sheets checkin log
# Leave blank to disable Sheets logging
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_FILE=/app/credentials/google_service_account.json
